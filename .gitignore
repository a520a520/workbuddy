# WorkBuddy 备份仓库 .gitignore
# 此仓库只备份核心记忆和配置，不包含运行时数据

# 运行时数据（不备份）
claw-state/
logs/
local_storage/
artifact-index/
connectors-marketplace-state/
plugin-marketplace-state/
projects/*/memory/backups/
*.log

# 敏感信息（不备份）
settings.json
settings-*.json
*.token
*.secret

# Windows 路径格式文件（不备份）
projects/Users-*/
projects/C-*/

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
